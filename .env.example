PORT=3000

# Gere um valor forte e aleatório, nunca reaproveite este exemplo.
# Sugestão pra gerar um: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque_por_um_valor_aleatorio_de_pelo_menos_32_caracteres
JWT_EXPIRES_IN=8h

# Credenciais de e-mail (use uma senha de app, nunca a senha normal da conta)
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=

LOGO_URL=

# Origem(ns) permitidas para o CORS, separadas por vírgula.
# Em produção, NÃO deixe em branco/"*" — coloque a URL real do painel/cardápio.
ALLOWED_ORIGINS=http://localhost:3000